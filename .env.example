# Database
DATABASE_URL="postgresql://user:password@localhost:5432/photizo_haven?schema=public"

# JWT — use `openssl rand -base64 64` in production
JWT_SECRET="replace-with-64-byte-random-secret"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# AES-256 field encryption — 32-byte hex key
FIELD_ENCRYPTION_KEY="replace-with-64-char-hex-key"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Capacitor Android APK — URL loaded in the WebView
# Production: https://your-deployed-app.com
# Emulator + local dev: http://10.0.2.2:3000
# Physical device: http://YOUR_LAN_IP:3000
CAPACITOR_SERVER_URL="http://localhost:3000"

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
