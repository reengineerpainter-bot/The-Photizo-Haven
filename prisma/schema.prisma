generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MEMBER
  MANAGER
  ADMIN

  @@map("user_role")
}

enum GivingCategory {
  TITHE
  PCO_SEED
  HAVEN_DUES
  WELFARE
  LOCAL_PARTNERSHIP

  @@map("giving_category")
}

enum ConsistencyStatus {
  OUTSTANDING
  CONSISTENT
  LAGGING
  LAPSED

  @@map("consistency_status")
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  MFA_ENABLED
  MFA_VERIFIED
  PROFILE_UPDATE
  GIVING_RECORDED
  ADMIN_COMMENT
  ADMIN_FEEDBACK
  REPORT_GENERATED
  MEMBER_CREATED
  ROLE_CHANGED

  @@map("audit_action")
}

model Group {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users               User[]
  givingRecords       GivingRecord[]
  partnershipProjects PartnershipProject[]
  adminComments       AdminComment[]
  memberFeedback      MemberFeedback[]

  @@map("groups")
}

model User {
  id             String            @id @default(uuid()) @db.Uuid
  groupId        String            @map("group_id") @db.Uuid
  role           UserRole          @default(MEMBER)
  fullName       String            @map("full_name") @db.VarChar(200)
  phoneEncrypted String            @map("phone_encrypted")
  phoneHash      String            @map("phone_hash") @db.VarChar(64)
  emailEncrypted String            @map("email_encrypted")
  emailHash      String            @unique @map("email_hash") @db.VarChar(64)
  passwordHash   String            @map("password_hash")
  dateJoined     DateTime          @map("date_joined") @db.Date
  mfaSecret      String?           @map("mfa_secret")
  mfaEnabled     Boolean           @default(false) @map("mfa_enabled")
  lastGivingAt   DateTime?         @map("last_giving_at")
  consistency    ConsistencyStatus @default(CONSISTENT)
  isActive       Boolean           @default(true) @map("is_active")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  group          Group            @relation(fields: [groupId], references: [id])
  givingRecords  GivingRecord[]
  givingTargets  GivingTarget[]
  refreshTokens  RefreshToken[]
  notifications  Notification[]
  commentsMade   AdminComment[]   @relation("ManagerComments")
  commentsReceived AdminComment[] @relation("MemberComments")
  feedbackSent   MemberFeedback[] @relation("ManagerFeedback")
  feedbackReceived MemberFeedback[] @relation("MemberFeedback")

  @@index([groupId])
  @@index([emailHash])
  @@map("users")
}

model GivingRecord {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String         @map("user_id") @db.Uuid
  groupId     String         @map("group_id") @db.Uuid
  category    GivingCategory
  amount      Decimal        @db.Decimal(12, 2)
  currency    String         @default("GHS") @db.Char(3)
  recordedAt  DateTime       @default(now()) @map("recorded_at")
  periodMonth DateTime       @map("period_month") @db.Date
  notes       String?
  projectDesc String?        @map("project_desc")
  createdAt   DateTime       @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id])

  @@unique([userId, category, periodMonth])
  @@index([userId])
  @@index([groupId])
  @@map("giving_records")
}

model GivingTarget {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  category      GivingCategory
  targetAmount  Decimal        @map("target_amount") @db.Decimal(12, 2)
  isPercentage  Boolean        @default(false) @map("is_percentage")
  percentage    Decimal?       @db.Decimal(5, 2)
  effectiveFrom DateTime       @default(now()) @map("effective_from") @db.Date
  createdAt     DateTime       @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@map("giving_targets")
}

model PartnershipProject {
  id           String   @id @default(uuid()) @db.Uuid
  groupId      String   @map("group_id") @db.Uuid
  title        String   @db.VarChar(200)
  description  String
  activeMonth  DateTime @map("active_month") @db.Date
  createdById  String   @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, activeMonth])
  @@map("partnership_projects")
}

model AdminComment {
  id        String   @id @default(uuid()) @db.Uuid
  memberId  String   @map("member_id") @db.Uuid
  managerId String   @map("manager_id") @db.Uuid
  groupId   String   @map("group_id") @db.Uuid
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  member  User  @relation("MemberComments", fields: [memberId], references: [id], onDelete: Cascade)
  manager User  @relation("ManagerComments", fields: [managerId], references: [id], onDelete: Cascade)
  group   Group @relation(fields: [groupId], references: [id])

  @@index([memberId])
  @@map("admin_comments")
}

model MemberFeedback {
  id        String   @id @default(uuid()) @db.Uuid
  memberId  String   @map("member_id") @db.Uuid
  managerId String   @map("manager_id") @db.Uuid
  groupId   String   @map("group_id") @db.Uuid
  subject   String   @db.VarChar(200)
  body      String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  member  User  @relation("MemberFeedback", fields: [memberId], references: [id], onDelete: Cascade)
  manager User  @relation("ManagerFeedback", fields: [managerId], references: [id], onDelete: Cascade)
  group   Group @relation(fields: [groupId], references: [id])

  @@index([memberId])
  @@map("member_feedback")
}

model Notification {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  type        String   @db.VarChar(50)
  title       String   @db.VarChar(200)
  body        String
  isRead      Boolean  @default(false) @map("is_read")
  triggeredAt DateTime @default(now()) @map("triggered_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model AuditLog {
  id           String      @id @default(uuid()) @db.Uuid
  actorId      String?     @map("actor_id") @db.Uuid
  groupId      String?     @map("group_id") @db.Uuid
  action       AuditAction
  resourceType String?     @map("resource_type") @db.VarChar(50)
  resourceId   String?     @map("resource_id") @db.Uuid
  ipAddress    String?     @map("ip_address")
  userAgent    String?     @map("user_agent")
  metadata     Json        @default("{}")
  createdAt    DateTime    @default(now()) @map("created_at")

  @@index([actorId])
  @@index([groupId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_log")
}
